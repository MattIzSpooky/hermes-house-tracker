{
  "uid": "hermes-backend",
  "title": "Hermes Backend",
  "tags": ["hermes", "backend", "spring-boot"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0
      },
      {
        "type": "custom",
        "name": "service_name",
        "label": "Service",
        "query": "hermes-backend",
        "options": [{ "text": "hermes-backend", "value": "hermes-backend" }],
        "current": { "text": "hermes-backend", "value": "hermes-backend" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_server_requests_milliseconds_count{service_name=\"$service_name\"}[2m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(sum(rate(http_server_requests_milliseconds_count{service_name=\"$service_name\",outcome=~\"CLIENT_ERROR|SERVER_ERROR\"}[2m])) or vector(0)) / sum(rate(http_server_requests_milliseconds_count{service_name=\"$service_name\"}[2m]))",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "id": 3,
      "title": "P95 Latency",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_milliseconds_bucket{service_name=\"$service_name\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM Heap Used",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(jvm_memory_used_bytes{service_name=\"$service_name\",area=\"heap\"}) / sum(jvm_memory_max_bytes{service_name=\"$service_name\",area=\"heap\"})",
          "legendFormat": "heap"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP Requests / sec — by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(http_server_requests_milliseconds_count{service_name=\"$service_name\"}[2m])) by (method, uri, status)",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "P95 / P99 Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 1, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_milliseconds_bucket{service_name=\"$service_name\"}[5m])) by (le))",
          "legendFormat": "p99"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_milliseconds_bucket{service_name=\"$service_name\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_milliseconds_bucket{service_name=\"$service_name\"}[5m])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 7,
      "title": "JVM Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 1, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(jvm_memory_used_bytes{service_name=\"$service_name\", area=\"heap\"}) by (id)",
          "legendFormat": "heap / {{id}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(jvm_memory_used_bytes{service_name=\"$service_name\", area=\"nonheap\"}) by (id)",
          "legendFormat": "non-heap / {{id}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(jvm_memory_max_bytes{service_name=\"$service_name\", area=\"heap\"}) by (id)",
          "legendFormat": "heap max / {{id}}",
          "hide": true
        }
      ]
    },
    {
      "id": 8,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "process_cpu_usage{service_name=\"$service_name\"}",
          "legendFormat": "process CPU"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_cpu_usage{service_name=\"$service_name\"}",
          "legendFormat": "system CPU"
        }
      ]
    },
    {
      "id": 9,
      "title": "HikariCP Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hikaricp_connections_active{service_name=\"$service_name\"}",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hikaricp_connections_idle{service_name=\"$service_name\"}",
          "legendFormat": "idle"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hikaricp_connections_pending{service_name=\"$service_name\"}",
          "legendFormat": "pending"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hikaricp_connections_max{service_name=\"$service_name\"}",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 10,
      "title": "JVM Threads & GC",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_threads_live{service_name=\"$service_name\"}",
          "legendFormat": "live threads"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_threads_daemon{service_name=\"$service_name\"}",
          "legendFormat": "daemon threads"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(jvm_gc_pause_milliseconds_sum{service_name=\"$service_name\"}[1m]) * 1000",
          "legendFormat": "GC pause ms/s"
        }
      ]
    },
    {
      "id": 11,
      "title": "AI Chat",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 }
    },
    {
      "id": 12,
      "title": "Total Chat Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(hermes_ai_chat_requests_total{service_name=\"$service_name\"})",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "id": 13,
      "title": "Chat Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(hermes_ai_chat_requests_total{service_name=\"$service_name\",outcome=\"success\"}) / sum(hermes_ai_chat_requests_total{service_name=\"$service_name\"})",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "id": 14,
      "title": "Avg LLM Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hermes_ai_chat_duration_milliseconds_sum{service_name=\"$service_name\",outcome=\"success\"} / hermes_ai_chat_duration_milliseconds_count{service_name=\"$service_name\",outcome=\"success\"}",
          "legendFormat": "avg duration"
        }
      ]
    },
    {
      "id": 15,
      "title": "P99 LLM Duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15000 },
              { "color": "red", "value": 45000 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(hermes_ai_chat_duration_milliseconds_bucket{service_name=\"$service_name\",outcome=\"success\"}[5m])) by (le))",
          "legendFormat": "p99 duration"
        }
      ]
    },
    {
      "id": 16,
      "title": "Avg Time to First Token",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 15000 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hermes_ai_chat_time_to_first_token_milliseconds_sum{service_name=\"$service_name\"} / hermes_ai_chat_time_to_first_token_milliseconds_count{service_name=\"$service_name\"}",
          "legendFormat": "avg TTFT"
        }
      ]
    },
    {
      "id": 17,
      "title": "P99 Time to First Token",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 20000 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(hermes_ai_chat_time_to_first_token_milliseconds_bucket{service_name=\"$service_name\"}[5m])) by (le))",
          "legendFormat": "p99 TTFT"
        }
      ]
    },
    {
      "id": 18,
      "title": "LLM Response Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 1, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(hermes_ai_chat_duration_milliseconds_bucket{service_name=\"$service_name\",outcome=\"success\"}[5m])) by (le))",
          "legendFormat": "p99 duration (5m)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(hermes_ai_chat_duration_milliseconds_sum{service_name=\"$service_name\",outcome=\"success\"}[5m]) / rate(hermes_ai_chat_duration_milliseconds_count{service_name=\"$service_name\",outcome=\"success\"}[5m])",
          "legendFormat": "avg duration (5m)"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(hermes_ai_chat_time_to_first_token_milliseconds_bucket{service_name=\"$service_name\"}[5m])) by (le))",
          "legendFormat": "p99 TTFT (5m)"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(hermes_ai_chat_time_to_first_token_milliseconds_sum{service_name=\"$service_name\"}[5m]) / rate(hermes_ai_chat_time_to_first_token_milliseconds_count{service_name=\"$service_name\"}[5m])",
          "legendFormat": "avg TTFT (5m)"
        }
      ]
    },
    {
      "id": 19,
      "title": "Tool Calls",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 1, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(hermes_ai_tool_calls_total{service_name=\"$service_name\"}[5m])",
          "legendFormat": "{{tool}} / rate"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hermes_ai_tool_calls_total{service_name=\"$service_name\"}",
          "legendFormat": "{{tool}} / total"
        }
      ]
    }
  ],
  "schemaVersion": 38
}
